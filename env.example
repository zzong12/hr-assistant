# ============================================================================
# HR数字助手 - 环境变量配置模板
# ============================================================================
# 复制此文件为 .env.local 并填入实际值
# 注意: .env.local 文件已加入 .gitignore，不会提交到代码库
# ============================================================================

# ----------------------------------------------------------------------------
# API 密钥配置
# ----------------------------------------------------------------------------

# Anthropic API Key (必需)
# 获取地址: https://console.anthropic.com/
# 用途: 调用Claude AI模型进行对话和内容生成
ANTHROPIC_API_KEY=your_api_key_here

# API 配置
# Anthropic API 版本
ANTHROPIC_API_VERSION=2023-06-01

# API 超时设置（毫秒）
ANTHROPIC_TIMEOUT=60000

# ----------------------------------------------------------------------------
# 应用配置
# ----------------------------------------------------------------------------

# 应用名称（客户端可见）
NEXT_PUBLIC_APP_NAME=HR数字助手

# 应用版本
NEXT_PUBLIC_APP_VERSION=1.0.0

# 应用描述
NEXT_PUBLIC_APP_DESCRIPTION=基于Claude Agent SDK的智能HR招聘助手

# ----------------------------------------------------------------------------
# 环境标识
# ----------------------------------------------------------------------------

# 运行环境: development | test | production
NODE_ENV=development

# ----------------------------------------------------------------------------
# 服务配置
# ----------------------------------------------------------------------------

# 服务端口（开发环境）
PORT=3000

# 服务主机名（开发环境）
HOSTNAME=localhost

# ----------------------------------------------------------------------------
# 数据存储配置
# ----------------------------------------------------------------------------

# 数据存储路径（相对于项目根目录）
DATA_DIR=./data

# 是否启用数据持久化
DATA_PERSISTENCE=true

# 数据备份间隔（小时）
DATA_BACKUP_INTERVAL=24

# ----------------------------------------------------------------------------
# 功能开关
# ----------------------------------------------------------------------------

# 是否启用AI功能
ENABLE_AI_FEATURES=true

# 是否启用简历解析
ENABLE_RESUME_PARSING=true

# 是否启用面试提醒
ENABLE_INTERVIEW_REMINDERS=false

# 是否启用数据分析
ENABLE_ANALYTICS=false

# ----------------------------------------------------------------------------
# AI Agent 配置
# ----------------------------------------------------------------------------

# 默认使用的Claude模型
DEFAULT_CLAUDE_MODEL=claude-3-5-sonnet-20241022

# AI 响应最大Token数
MAX_TOKENS=4096

# AI 响应温度（0-1，越高越随机）
TEMPERATURE=0.7

# 对话历史保留轮数
CONVERSATION_HISTORY_LIMIT=10

# JD生成详细程度（basic | standard | detailed）
JD_GENERATION_DETAIL=standard

# 候选人匹配阈值（0-100）
CANDIDATE_MATCH_THRESHOLD=60

# ----------------------------------------------------------------------------
# 文件上传配置
# ----------------------------------------------------------------------------

# 最大文件大小（MB）
MAX_FILE_SIZE=10

# 允许的文件类型
ALLOWED_FILE_TYPES=.pdf,.doc,.docx,.txt

# 简历文件保存路径
RESUME_UPLOAD_DIR=./data/resumes

# ----------------------------------------------------------------------------
# 面试配置
# ----------------------------------------------------------------------------

# 默认面试时长（分钟）
DEFAULT_INTERVIEW_DURATION=60

# 面试时间缓冲期（分钟）
INTERVIEW_BUFFER_TIME=15

# 面试提醒提前时间（小时）
INTERVIEW_REMINDER_HOURS=24

# ----------------------------------------------------------------------------
# 限流和安全配置
# ----------------------------------------------------------------------------

# API 请求速率限制（每分钟请求数）
RATE_LIMIT_PER_MINUTE=60

# 单个用户每日对话次数限制
DAILY_CONVERSATION_LIMIT=100

# 会话超时时间（分钟）
SESSION_TIMEOUT=30

# ----------------------------------------------------------------------------
# 日志配置
# ----------------------------------------------------------------------------

# 日志级别: debug | info | warn | error
LOG_LEVEL=info

# 是否启用详细日志
VERBOSE_LOGGING=false

# 日志文件路径
LOG_FILE_PATH=./logs

# ----------------------------------------------------------------------------
# 性能配置
# ----------------------------------------------------------------------------

# 是否启用性能监控
ENABLE_PERFORMANCE_MONITORING=true

# API 响应缓存时间（秒）
API_CACHE_TTL=300

# 是否启用数据预加载
ENABLE_DATA_PRELOADING=true

# ----------------------------------------------------------------------------
# 外部服务配置（可选）
# ----------------------------------------------------------------------------

# 邮件服务配置（用于发送面试通知等）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM=HR数字助手 <noreply@example.com>

# 日历服务配置（用于面试日历集成）
CALENDAR_API_KEY=your_calendar_api_key
CALENDAR_PROVIDER=google

# ----------------------------------------------------------------------------
# 开发和调试配置
# ----------------------------------------------------------------------------

# 是否启用调试模式
DEBUG=false

# 是否启用热重载
HOT_RELOAD=true

# 是否显示技术栈信息
SHOW_TECH_STACK_INFO=true

# 是否启用开发工具栏
ENABLE_DEV_TOOLBAR=true

# ----------------------------------------------------------------------------
# 第三方分析（可选）
# ----------------------------------------------------------------------------

# Google Analytics
NEXT_PUBLIC_GA_ID=

# 埋点分析
NEXT_PUBLIC_PUBLIC_DSN=

# ----------------------------------------------------------------------------
# 高级配置（通常不需要修改）
# ----------------------------------------------------------------------------

# Node.js 内存限制（MB）
NODE_MAX_OLD_SPACE_SIZE=4096

# 是否启用实验性功能
ENABLE_EXPERIMENTAL_FEATURES=false

# 功能标志位（Feature Flags）
FEATURE_MULTI_TENANT=false
FEATURE_SSO=false
FEATURE_WEBHOOK=false